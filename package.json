{
    "name": "onscan.js",
    "version": "1.5.2",
    "description": "Framework agnostic onScan event fired when using hardware barcode scanners",
    "main": "dist/onscan.umd.js",
    "module": "dist/onscan.esm.js",
    "types": "onscan.d.ts",
    "repository": {
        "type": "git",
        "url": "git+https://github.com/Shockwave3301/onScan.git"
    },
    "keywords": [
        "barcode",
        "RFID",
        "scanner",
        "scan"
    ],
    "author": "Shakhbulat Gazgireev",
    "license": "MIT",
    "bugs": {
        "url": "https://github.com/Shockwave3301/onScan/issues"
    },
    "homepage": "https://github.com/Shockwave3301/onScan",
    "engines": {
        "node": ">=20"
    },
    "scripts": {
        "build": "rollup -c rollup.config.mjs",
        "test": "vitest run",
        "test:watch": "vitest",
        "lint": "eslint src/",
        "format": "prettier --write src/",
        "format:check": "prettier --check src/",
        "typecheck": "tsc --noEmit"
    },
    "devDependencies": {
        "@eslint/js": "^9.39.2",
        "@rollup/plugin-terser": "^0.4.4",
        "eslint": "^9.39.2",
        "eslint-config-prettier": "^10.1.8",
        "jsdom": "^27.0.1",
        "prettier": "^3.8.1",
        "rollup": "^4.57.1",
        "typescript": "^5.9.3",
        "vitest": "^3.2.4"
    }
}
